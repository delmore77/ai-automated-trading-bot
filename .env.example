# TradingView Webhook Bot - Environment
# Copy to .env and fill in your keys (never commit .env)

# Webhook
WEBHOOK_SECRET=your_webhook_secret_here
REQUIRE_WEBHOOK_SECRET=true
RATE_LIMIT_PER_MINUTE=30
IDEMPOTENCY_TTL_SECONDS=86400

# Binance (optional - leave empty to disable)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# Bybit (optional)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

# OKX (optional)
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_SANDBOX=false

# Hyperliquid (optional)
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_WALLET_ADDRESS=
HYPERLIQUID_TESTNET=false

# Risk (use higher values on testnets to allow large test orders, e.g. MAX_POSITION_SIZE_USDT=100000)
MAX_POSITION_SIZE_USDT=1000
MAX_LEVERAGE=10
MAX_DAILY_LOSS_USDT=500
ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT
MAX_POSITION_PER_SYMBOL_USDT=0
MAX_TOTAL_EXPOSURE_USDT=0
COOLDOWN_AFTER_LOSS_MINUTES=60
MAX_SPREAD_PCT=0

# Execution
DRY_RUN=false
ORDER_RETRIES=2
ORDER_RETRY_DELAY_SECONDS=1.0

# Trailing stop
TRAILING_STOP_CHECK_INTERVAL_SECONDS=30

# AI / LLM (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_ADVISOR_ENABLED=false
AI_ENHANCER_ENABLED=false
AI_SIGNAL_ENABLED=false
AI_SIGNAL_SECRET=

# DB
DB_PATH=webhook_bot.db

# Server
HOST=0.0.0.0
PORT=8000
